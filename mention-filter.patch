From 9cb66c3028c22e01bfd5741f91f4d4c70e5cf609 Mon Sep 17 00:00:00 2001
From: Codi Saint <codi@pop-os.tailb0b4db.ts.net>
Date: Sat, 21 Feb 2026 17:17:11 -0500
Subject: [PATCH] Filter OpenClaw webhook to only forward mentioned messages

Only forwards messages containing @Codi, @openclaw, or starting with those names.
This prevents all chat messages from being sent to the bridge - only messages
intended for the AI assistant are forwarded.
---
 src/server.ts | 13 +++++++++++++
 1 file changed, 13 insertions(+)

diff --git a/src/server.ts b/src/server.ts
index e59603d..345ce57 100644
--- a/src/server.ts
+++ b/src/server.ts
@@ -219,10 +219,21 @@ const OPENCLAW_ENABLED = process.env.OPENCLAW_ENABLED !== 'false'; // Enabled by
 /**
  * Forward a chat message to OpenClaw for AI processing
  * Called when a message is sent in a channel/conversation that should trigger AI responses
+ * Only forwards messages that mention @Codi, @openclaw, or @codi (case-insensitive)
  */
 async function forwardToOpenClaw(message: { id: string; content: string; userId: string; username: string; conversationId: string; timestamp: number }) {
     if (!OPENCLAW_ENABLED || !OPENCLAW_WEBHOOK_URL) return;
 
+    // Only forward messages that explicitly mention the bot
+    const contentLower = message.content.toLowerCase();
+    const shouldForward = contentLower.includes('@codi') || 
+                          contentLower.includes('@openclaw') ||
+                          contentLower.includes('@@codi') ||  // @@ for bot mention syntax
+                          contentLower.startsWith('codi ') ||
+                          contentLower.startsWith('openclaw ');
+
+    if (!shouldForward) return;
+
     try {
         const response = await fetch(OPENCLAW_WEBHOOK_URL, {
             method: 'POST',
@@ -243,6 +254,8 @@ async function forwardToOpenClaw(message: { id: string; content: string; userId:
 
         if (!response.ok) {
             log('WARN', `OpenClaw webhook failed: ${response.status}`);
+        } else {
+            log('INFO', `OpenClaw webhook sent for message ${message.id}`);
         }
     } catch (error) {
         // Don't fail the message if OpenClaw is unavailable
