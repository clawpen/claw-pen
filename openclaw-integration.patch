+// --- OPENCLAW INTEGRATION ---
+// Configure this URL to point to your OpenClaw instance's webhook endpoint
+const OPENCLAW_WEBHOOK_URL = process.env.OPENCLAW_WEBHOOK_URL || 'http://localhost:3000/webhook/andor';
+const OPENCLAW_ENABLED = process.env.OPENCLAW_ENABLED !== 'false'; // Enabled by default
+
+/**
+ * Forward a chat message to OpenClaw for AI processing
+ * Called when a message is sent in a channel/conversation that should trigger AI responses
+ */
+async function forwardToOpenClaw(message: { id: string; content: string; userId: string; username: string; conversationId: string; timestamp: number }) {
+    if (!OPENCLAW_ENABLED || !OPENCLAW_WEBHOOK_URL) return;
+
+    try {
+        const response = await fetch(OPENCLAW_WEBHOOK_URL, {
+            method: 'POST',
+            headers: { 'Content-Type': 'application/json' },
+            body: JSON.stringify({
+                type: 'message',
+                channel: 'andor-chat',
+                data: {
+                    messageId: message.id,
+                    content: message.content,
+                    senderId: message.userId,
+                    senderName: message.username,
+                    conversationId: message.conversationId,
+                    timestamp: message.timestamp
+                }
+            })
+        });
+
+        if (!response.ok) {
+            log('WARN', `OpenClaw webhook failed: ${response.status}`);
+        }
+    } catch (error) {
+        // Don't fail the message if OpenClaw is unavailable
+        log('WARN', `OpenClaw webhook error: ${(error as Error).message}`);
+    }
+}
