+        // --- OPENCLAW INTEGRATION ENDPOINTS ---
+        // POST /api/openclaw/message - Receive a message from OpenClaw to broadcast to chat
+        if (method === 'POST' && url === '/api/openclaw/message') {
+            const chunks: any[] = [];
+            req.on('data', c => chunks.push(c));
+            req.on('end', () => {
+                try {
+                    const body = JSON.parse(Buffer.concat(chunks).toString());
+                    const { conversationId, content, senderName, senderId } = body;
+
+                    if (!conversationId || !content) {
+                        sendJSON(400, { error: 'Missing conversationId or content' });
+                        return;
+                    }
+
+                    log('INFO', `OpenClaw message for conversation ${conversationId}: ${content.substring(0, 50)}...`);
+
+                    // Ensure conversation exists
+                    ensureConversation(conversationId, senderId || 'openclaw-bot');
+
+                    // Create message in database
+                    const savedMessage = createMessage(
+                        senderId || 'openclaw-bot',
+                        conversationId,
+                        content
+                    );
+
+                    // Broadcast to all connected WebSocket clients
+                    const broadcast = JSON.stringify({
+                        type: 'new_message',
+                        message: {
+                            ...savedMessage,
+                            username: senderName || 'Codi'
+                        }
+                    });
+
+                    let sentCount = 0;
+                    for (const c of clients.values()) {
+                        if (c.readyState === WebSocket.OPEN) {
+                            c.send(broadcast);
+                            sentCount++;
+                        }
+                    }
+
+                    log('INFO', `OpenClaw message broadcast to ${sentCount} clients`);
+                    sendJSON(200, { success: true, messageId: savedMessage.id, clients: sentCount });
+                } catch (error) {
+                    log('ERROR', `OpenClaw message error: ${(error as Error).message}`);
+                    sendJSON(500, { error: 'Failed to process message' });
+                }
+            });
+            return;
+        }
+
+        // GET /api/openclaw/conversations - List conversations for OpenClaw to discover
+        if (method === 'GET' && url === '/api/openclaw/conversations') {
+            try {
+                const conversations = getConversations(100);
+                sendJSON(200, { conversations });
+            } catch (error) {
+                log('ERROR', `Failed to list conversations: ${(error as Error).message}`);
+                sendJSON(500, { error: 'Failed to list conversations' });
+            }
+            return;
+        }
+
+        // GET /api/openclaw/messages/:conversationId - Get recent messages for a conversation
+        if (method === 'GET' && url.startsWith('/api/openclaw/messages/')) {
+            try {
+                const conversationId = decodeURIComponent(url.split('/')[4]?.split('?')[0] || '');
+                const urlObj = new URL(url, `http://${req.headers.host}`);
+                const limit = parseInt(urlObj.searchParams.get('limit') || '50', 10);
+
+                if (!conversationId) {
+                    sendJSON(400, { error: 'Missing conversationId' });
+                    return;
+                }
+
+                const messages = getRecentMessages(conversationId, limit);
+                sendJSON(200, { conversationId, messages, count: messages.length });
+            } catch (error) {
+                log('ERROR', `Failed to get messages: ${(error as Error).message}`);
+                sendJSON(500, { error: 'Failed to get messages' });
+            }
+            return;
+        }
+
+        // POST /api/openclaw/config - Update OpenClaw webhook URL (optional, for runtime config)
+        if (method === 'POST' && url === '/api/openclaw/config') {
+            const chunks: any[] = [];
+            req.on('data', c => chunks.push(c));
+            req.on('end', () => {
+                try {
+                    const body = JSON.parse(Buffer.concat(chunks).toString());
+                    const { webhookUrl, enabled } = body;
+
+                    // Note: In production, you'd want to persist this to the database
+                    // For now, this is runtime-only
+                    if (webhookUrl !== undefined) {
+                        log('INFO', `OpenClaw webhook URL updated (runtime only): ${webhookUrl}`);
+                    }
+                    if (enabled !== undefined) {
+                        log('INFO', `OpenClaw ${enabled ? 'enabled' : 'disabled'} (runtime only)`);
+                    }
+
+                    sendJSON(200, {
+                        success: true,
+                        currentConfig: {
+                            webhookUrl: OPENCLAW_WEBHOOK_URL,
+                            enabled: OPENCLAW_ENABLED
+                        }
+                    });
+                } catch (error) {
+                    sendJSON(500, { error: 'Failed to update config' });
+                }
+            });
+            return;
+        }
+
         // --- FOLDER ENDPOINTS (Non-git folders) ---
