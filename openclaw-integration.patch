+// --- OPENCLAW INTEGRATION ---
+export const getConversations = (limit = 100): { conversation_id: string; created_at: string }[] => {
+    return db.prepare(`
+        SELECT DISTINCT conversation_id, MIN(created_at) as created_at
+        FROM messages
+        WHERE conversation_id IS NOT NULL
+        GROUP BY conversation_id
+        ORDER BY created_at DESC
+        LIMIT ?
+    `).all(limit) as { conversation_id: string; created_at: string }[];
+};
