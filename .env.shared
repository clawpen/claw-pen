# Claw Pen - Shared Port Configuration
# Source this file in both orchestrator and frontend builds

ORCHESTRATOR_HOST=127.0.0.1
ORCHESTRATOR_PORT=3001
ORCHESTRATOR_URL=http://${ORCHESTRATOR_HOST}:${ORCHESTRATOR_PORT}
ORCHESTRATOR_WS_URL=ws://${ORCHESTRATOR_HOST}:${ORCHESTRATOR_PORT}

LLAMACPP_HOST=host.docker.internal
LLAMACPP_PORT=8081
LLAMACPP_URL=http://${LLAMACPP_HOST}:${LLAMACPP_PORT}/v1

AGENT_PORT_BASE=18790
