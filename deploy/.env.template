# AndOR Hub Configuration
# Copy this file to .env and fill in your values

# Server
PORT=8080
HOST=0.0.0.0
NODE_ENV=production

# Database (SQLite - no config needed)
DATABASE_PATH=./local_chat.db

# OpenClaw Integration
OPENCLAW_WEBHOOK_URL=http://localhost:3456/webhook
OPENCLAW_ENABLED=true

# Git Server
GIT_ROOT=./git-data
GIT_ENABLED=true

# File Storage (MinIO or local)
STORAGE_TYPE=local
STORAGE_PATH=./uploads
# For MinIO:
# STORAGE_TYPE=minio
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
# MINIO_ACCESS_KEY=your-access-key
# MINIO_SECRET_KEY=your-secret-key

# Docker Integration (optional)
DOCKER_ENABLED=true
DOCKER_SOCKET=/var/run/docker.sock

# Build Environments (optional)
BUILDS_ENABLED=true
BUILDS_PATH=./builds

# JWT Secret (generate a random string!)
JWT_SECRET=change-this-to-a-random-string

# Optional: Claude Integration
# CLAUDE_API_KEY=your-claude-api-key

# Optional: External URL (for webhooks, etc.)
# PUBLIC_URL=https://your-domain.com
